{
  "name": "color-by",
  "parent": "gridpoint",
  "description": "Color-by modes for gridpoint plot items. These include FLAC2D and FLAC3D values; z components are FLAC3D-only.",
  "modes": [
    {
      "keyword": "color-by vector-attribute",
      "description": "Color gridpoints by vector values.",
      "syntax": "color-by vector-attribute \"<name>\"",
      "examples": [
        "color-by vector-attribute \"displacement\"",
        "color-by vector-attribute \"velocity\"",
        "color-by vector-attribute \"force-unbalanced\""
      ],
      "available_attributes": [
        "displacement",
        "force-unbalanced",
        "position",
        "velocity"
      ]
    },
    {
      "keyword": "color-by numeric-attribute",
      "description": "Color gridpoints by scalar values.",
      "syntax": "color-by numeric-attribute \"<name>\"",
      "examples": [
        "color-by numeric-attribute \"pore-pressure\"",
        "color-by numeric-attribute \"temperature\"",
        "color-by numeric-attribute \"extra\" 1"
      ],
      "available_attributes": [
        "extra",
        "pore-pressure",
        "ratio-local",
        "temperature"
      ]
    },
    {
      "keyword": "color-by text-attribute",
      "description": "Color gridpoints by categorical values.",
      "syntax": "color-by text-attribute \"<name>\"",
      "examples": [
        "color-by text-attribute \"group\" 'Any' color-options named maximum-names 1000000 name-controls true",
        "color-by text-attribute \"id\" color-options named maximum-names 1000000 name-controls true"
      ],
      "available_attributes": [
        "group",
        "id"
      ]
    }
  ]
}
