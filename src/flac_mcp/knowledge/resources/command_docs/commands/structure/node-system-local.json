{
  "category": "structure",
  "search_keywords": [
    "node",
    "system",
    "local",
    "structure",
    "system-local"
  ],
  "description": "Set the orientation of the node-local system for all nodes in the range.",
  "python_sdk_alternative": {
    "available": false
  },
  "versions": {
    "9.0": {
      "command": "structure node system-local",
      "syntax": "structure node system-local keyword ... [range]",
      "keywords": [
        {
          "name": "x",
          "syntax": "x <v>",
          "description": "specifies the local \\(x\\) -direction"
        },
        {
          "name": "y",
          "syntax": "y <v>",
          "description": "specifies the local \\(y\\) -direction"
        },
        {
          "name": "z",
          "syntax": "z <v>3D ONLY",
          "description": "specifies the local \\(z\\) -direction"
        },
        {
          "name": "reverse-x",
          "syntax": "reverse-x 2D ONLY",
          "description": "reverses the current \\(x\\) -direction (cannot be used with the \\(x\\) or \\(y\\) keywords)"
        },
        {
          "name": "reverse-y",
          "syntax": "reverse-y 2D ONLY",
          "description": "reverses the current \\(y\\) -direction (cannot be used with the \\(x\\) or \\(y\\) keywords)"
        }
      ]
    }
  }
}
